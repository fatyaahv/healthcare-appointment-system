<?xml version="1.0" encoding="UTF-8"?>
<appointmentSystem 
    xmlns="https://www.saglikrandevu.com/schema"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://www.saglikrandevu.com/schema schema.xsd">

    <clinics>
        <clinic>
            <clinicId>C01</clinicId>
            <clinicName>Kardiyoloji</clinicName>
            <doctors>
                <doctor>
                    <!-- HATA 1: Doktor ID formatı 'D' harfiyle başlamalıdır. 'DOC01' şemaya aykırıdır. -->
                    <doctorId>DOC01</doctorId>
                    <firstName>Ahmet</firstName>
                    <lastName>Yılmaz</lastName>
                    <email>ahmet.yilmaz@hastane.com</email>
                </doctor>
            </doctors>
        </clinic>
    </clinics>

    <patients>
        <patient>
            <patientId>P01</patientId>
            <firstName>Ayse</firstName>
            <lastName>Ozturk</lastName>
            <!-- HATA 2: Telefon numarası formatı '+90-XXX-XXX-XXXX' olmalıdır. '05551234567' şemaya aykırıdır. -->
            <phone>05551234567</phone>
            <email>ayse.ozturk@email.com</email>
            <dateOfBirth>1990-05-15</dateOfBirth>
        </patient>
    </patients>

    <appointments>
        <appointment>
            <appointmentId>A01</appointmentId>
            <doctorId>D01</doctorId>
            <patientId>P01</patientId>
            <appointmentDateTime>2026-06-01T09:00:00</appointmentDateTime>
            <!-- HATA 3: Randevu durumu sadece 'Pending', 'Completed' veya 'Cancelled' olabilir. 'Waiting' şemaya aykırıdır. -->
            <status>Waiting</status>
            <notes>Rutin kardiyoloji kontrolu.</notes>
        </appointment>
    </appointments>

</appointmentSystem>